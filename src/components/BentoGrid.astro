---
import {
  ArrowRight,
  BrainCircuit,
  CodeXml,
  DatabaseZap,
  Layers,
  Radar,
  Sparkles,
  SquareTerminal,
} from "@lucide/astro";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
const latest = posts[0];
const latestSlug =
  latest && "slug" in latest
    ? latest.slug
    : latest?.id.replace(/\.(md|mdx)$/i, "");
---

<section id="lab" class="site-container py-14 md:py-20">
  <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">
        Interactive Bento Grid
      </p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-4xl">
        一个可扩展的个人主页控制台
      </h2>
    </div>
    <p class="max-w-xl text-sm leading-7 text-slate-600 dark:text-slate-300">
      每张卡片都可以替换成你的项目、文章、工具、状态或联系方式。鼠标移动会驱动光斑、倾斜和高亮响应。
    </p>
  </div>

  <div class="grid auto-rows-[15rem] grid-cols-1 gap-4 md:grid-cols-6">
    <a
      class="bento-card p-6 md:col-span-4 md:row-span-2"
      style="--accent-card: 34 211 238"
      href="/blog"
    >
      <div class="flex h-full flex-col justify-between">
        <div class="flex items-center justify-between">
          <span class="grid size-11 place-items-center rounded-lg border border-cyan-500/30 bg-cyan-500/10 text-cyan-700 dark:text-cyan-200">
            <BrainCircuit class="size-5" aria-hidden="true" />
          </span>
          <ArrowRight class="size-5 text-slate-400 transition group-hover:text-cyan-500" aria-hidden="true" />
        </div>
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">
            Core Signal
          </p>
          <h3 class="text-balance font-display text-3xl font-semibold text-slate-950 dark:text-white md:text-5xl">
            将思考、代码与长期主义组织成一个可检索系统。
          </h3>
        </div>
      </div>
    </a>

    <div class="bento-card p-6 md:col-span-2" style="--accent-card: 124 255 178">
      <div class="flex h-full flex-col justify-between">
        <span class="grid size-11 place-items-center rounded-lg border border-emerald-400/30 bg-emerald-400/10 text-emerald-700 dark:text-emerald-200">
          <Radar class="size-5" aria-hidden="true" />
        </span>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">Now</p>
          <p class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white">Building in public</p>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
            Frontend systems, AI workflows, reliable notes, calm execution.
          </p>
        </div>
      </div>
    </div>

    <div class="bento-card p-6 md:col-span-2" style="--accent-card: 255 183 74">
      <div class="flex h-full flex-col justify-between">
        <span class="grid size-11 place-items-center rounded-lg border border-amber-400/30 bg-amber-400/10 text-amber-700 dark:text-amber-200">
          <SquareTerminal class="size-5" aria-hidden="true" />
        </span>
        <div class="grid grid-cols-2 gap-2 font-mono text-xs uppercase tracking-[0.18em] text-slate-500 dark:text-slate-300">
          <span class="rounded-md border border-slate-900/10 px-3 py-2 dark:border-white/10">Astro</span>
          <span class="rounded-md border border-slate-900/10 px-3 py-2 dark:border-white/10">MDX</span>
          <span class="rounded-md border border-slate-900/10 px-3 py-2 dark:border-white/10">Tailwind</span>
          <span class="rounded-md border border-slate-900/10 px-3 py-2 dark:border-white/10">GSAP</span>
        </div>
      </div>
    </div>

    {latest && (
      <a class="bento-card p-6 md:col-span-3" style="--accent-card: 244 114 182" href={`/blog/${latestSlug}`}>
        <div class="flex h-full flex-col justify-between">
          <div class="flex items-center justify-between">
            <span class="grid size-11 place-items-center rounded-lg border border-pink-400/30 bg-pink-400/10 text-pink-700 dark:text-pink-200">
              <Sparkles class="size-5" aria-hidden="true" />
            </span>
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-slate-400">
              <FormattedDate date={latest.data.pubDate} />
            </span>
          </div>
          <div>
            <p class="mb-2 font-mono text-xs uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
              Latest Note
            </p>
            <h3 class="font-display text-2xl font-semibold text-slate-950 dark:text-white">
              {latest.data.title}
            </h3>
          </div>
        </div>
      </a>
    )}

    <div class="bento-card p-6 md:col-span-3" style="--accent-card: 34 197 94">
      <div class="flex h-full flex-col justify-between">
        <div class="flex items-center gap-3">
          <span class="grid size-11 place-items-center rounded-lg border border-green-400/30 bg-green-400/10 text-green-700 dark:text-green-200">
            <DatabaseZap class="size-5" aria-hidden="true" />
          </span>
          <span class="font-mono text-xs uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
            Content Collections
          </span>
        </div>
        <div class="grid grid-cols-3 gap-3 text-center">
          <div class="rounded-lg border border-slate-900/10 p-3 dark:border-white/10">
            <p class="font-display text-2xl font-semibold text-slate-950 dark:text-white">{posts.length}</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Posts</p>
          </div>
          <div class="rounded-lg border border-slate-900/10 p-3 dark:border-white/10">
            <p class="font-display text-2xl font-semibold text-slate-950 dark:text-white">100</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Lighthouse</p>
          </div>
          <div class="rounded-lg border border-slate-900/10 p-3 dark:border-white/10">
            <p class="font-display text-2xl font-semibold text-slate-950 dark:text-white">0ms</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Runtime CMS</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bento-card p-6 md:col-span-3" style="--accent-card: 56 189 248">
      <div class="flex h-full flex-col justify-between">
        <span class="grid size-11 place-items-center rounded-lg border border-sky-400/30 bg-sky-400/10 text-sky-700 dark:text-sky-200">
          <Layers class="size-5" aria-hidden="true" />
        </span>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
            Deploy Ready
          </p>
          <p class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white">GitHub Pages / Vercel</p>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
            只需配置 DNS 指向 chancezone.net，即可把静态产物发布到你的独立域名。
          </p>
        </div>
      </div>
    </div>

    <div class="bento-card p-6 md:col-span-3" style="--accent-card: 168 85 247">
      <div class="flex h-full flex-col justify-between">
        <span class="grid size-11 place-items-center rounded-lg border border-violet-400/30 bg-violet-400/10 text-violet-700 dark:text-violet-200">
          <CodeXml class="size-5" aria-hidden="true" />
        </span>
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
            Custom Surface
          </p>
          <p class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white">组件化、主题化、可替换</p>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
            Bento 卡片、文章卡片、Callout 和 Layout 已拆分，后续扩展作品集或 newsletter 很直接。
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const bindBentoCards = () => {
    const cards = document.querySelectorAll<HTMLElement>(".bento-card");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    cards.forEach((card) => {
      if (card.dataset.bound === "true") return;
      card.dataset.bound = "true";

      card.addEventListener("pointermove", (event) => {
        const rect = card.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        card.style.setProperty("--mx", `${x}px`);
        card.style.setProperty("--my", `${y}px`);

        if (reduceMotion) return;
        const rotateY = ((x / rect.width) - 0.5) * 7;
        const rotateX = -((y / rect.height) - 0.5) * 7;
        gsap.to(card, {
          rotateX,
          rotateY,
          y: -4,
          duration: 0.34,
          ease: "power2.out",
        });
      });

      card.addEventListener("pointerleave", () => {
        if (reduceMotion) return;
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          y: 0,
          duration: 0.5,
          ease: "elastic.out(1, 0.5)",
        });
      });
    });

    if (!reduceMotion) {
      gsap.from(cards, {
        opacity: 0,
        y: 24,
        duration: 0.7,
        stagger: 0.06,
        ease: "power3.out",
        overwrite: "auto",
      });
    }
  };

  document.addEventListener("astro:page-load", bindBentoCards);
  bindBentoCards();
</script>
