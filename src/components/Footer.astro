---
import { SITE } from "../consts";

const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-slate-900/10 py-10 dark:border-white/10">
  <div class="site-container flex flex-col gap-4 text-sm text-slate-500 dark:text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {SITE.author}. Built with Astro, Tailwind CSS and GSAP.</p>
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">
      Deploy target: GitHub Pages / Vercel
    </p>
  </div>
</footer>
