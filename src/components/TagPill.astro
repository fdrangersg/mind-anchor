---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
const className =
  "inline-flex items-center rounded-md border border-slate-900/10 bg-slate-950/[0.03] px-2.5 py-1 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-slate-600 transition dark:border-white/10 dark:bg-white/[0.04] dark:text-slate-300";
---

{href ? (
  <a class={`${className} hover:border-cyan-500/50 hover:text-cyan-700 dark:hover:text-cyan-200`} href={href}>
    #{tag}
  </a>
) : (
  <span class={className}>#{tag}</span>
)}
