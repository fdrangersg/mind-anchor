---
import { Sparkles } from "@lucide/astro";

interface Props {
  tone?: "cyan" | "green" | "amber";
}

const { tone = "cyan" } = Astro.props;
const tones = {
  cyan: "border-cyan-500/30 bg-cyan-500/10 text-cyan-900 dark:text-cyan-100",
  green: "border-emerald-400/30 bg-emerald-400/10 text-emerald-900 dark:text-emerald-100",
  amber: "border-amber-400/40 bg-amber-400/10 text-amber-900 dark:text-amber-100",
};
---

<aside class={`my-8 flex gap-4 rounded-lg border p-4 ${tones[tone]}`}>
  <Sparkles class="mt-1 size-5 shrink-0" aria-hidden="true" />
  <div class="text-sm leading-7">
    <slot />
  </div>
</aside>
