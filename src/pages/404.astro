---
import { ArrowLeft } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="This page does not exist." noindex>
  <section class="site-container flex min-h-[68svh] flex-col items-start justify-center py-16">
    <p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">
      404
    </p>
    <h1 class="mt-4 font-display text-5xl font-semibold tracking-tight text-slate-950 dark:text-white">
      Page not found
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-8 text-slate-600 dark:text-slate-300">
      The page you are looking for is missing, moved, or still waiting to be written.
    </p>
    <a
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700 dark:bg-white dark:text-slate-950 dark:hover:bg-cyan-200"
      href="/"
    >
      <ArrowLeft class="size-4" aria-hidden="true" />
      Back home
    </a>
  </section>
</BaseLayout>
