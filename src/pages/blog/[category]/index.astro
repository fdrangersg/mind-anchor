---
import PostCard from "../../../components/PostCard.astro";
import TagPill from "../../../components/TagPill.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getBlogCategories,
  getPostCategory,
  getPublishedPosts,
  type BlogCategory,
  type BlogPost,
} from "../../../lib/blog";

interface Props {
  category: BlogCategory;
  posts: BlogPost[];
}

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const categories = getBlogCategories(posts);

  return categories.map((category) => ({
    params: { category: category.slug },
    props: {
      category,
      posts: posts.filter((post) => getPostCategory(post)?.slug === category.slug),
    },
  }));
}

const { category, posts } = Astro.props;
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
---

<BaseLayout
  title={category.label}
  description={`Published notes in ${category.label}.`}
>
  <section class="site-container py-14 md:py-20">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">
        Category
      </p>
      <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-6xl">
        {category.label}
      </h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
        Notes from <code>src/content/blog/{category.slug}/</code>.
      </p>
    </div>

    {tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {tags.map((tag) => <TagPill tag={tag} />)}
      </div>
    )}

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
