---
import { ArrowRight, BookOpen, Rss } from "@lucide/astro";
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../consts";
import { getPublishedPosts } from "../lib/blog";

const posts = await getPublishedPosts();
const featuredPosts = posts.slice(0, 6);
---

<BaseLayout title="Home" description={SITE.description} image={SITE.ogImage}>
  <section class="site-container py-16 md:py-24">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">
        Personal blog
      </p>
      <h1 class="mt-5 text-balance font-display text-5xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-7xl">
        Notes on everything that keeps my attention.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300 md:text-xl">
        {SITE.description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center gap-2 rounded-lg bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-cyan-700 focus:outline-none focus:ring-2 focus:ring-cyan-400 dark:bg-white dark:text-slate-950 dark:hover:bg-cyan-200"
          href="/blog"
        >
          <BookOpen class="size-4" aria-hidden="true" />
          Read the archive
        </a>
        <a
          class="inline-flex items-center gap-2 rounded-lg border border-slate-900/10 bg-white/70 px-5 py-3 text-sm font-semibold text-slate-700 shadow-sm shadow-slate-900/5 transition hover:border-cyan-500/50 hover:text-cyan-700 focus:outline-none focus:ring-2 focus:ring-cyan-400 dark:border-white/10 dark:bg-slate-950/50 dark:text-slate-200 dark:hover:text-cyan-200"
          href="/rss.xml"
        >
          <Rss class="size-4" aria-hidden="true" />
          RSS
        </a>
      </div>
    </div>
  </section>

  <section class="site-container pb-16 md:pb-24">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-700 dark:text-cyan-300">
          Latest
        </p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-slate-950 dark:text-white md:text-4xl">
          Recent writing
        </h2>
      </div>
      {posts.length > 0 && (
        <a
          class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-700 transition hover:text-cyan-900 dark:text-cyan-300 dark:hover:text-cyan-100"
          href="/blog"
        >
          View all
          <ArrowRight class="size-4" aria-hidden="true" />
        </a>
      )}
    </div>

    {featuredPosts.length > 0 ? (
      <div class="grid gap-4 md:grid-cols-2">
        {featuredPosts.map((post) => <PostCard post={post} featured />)}
      </div>
    ) : (
      <div class="rounded-lg border border-slate-900/10 bg-white/70 p-6 text-slate-600 shadow-sm shadow-slate-900/5 dark:border-white/10 dark:bg-slate-950/50 dark:text-slate-300">
        <p class="font-display text-2xl font-semibold text-slate-950 dark:text-white">
          No posts yet.
        </p>
        <p class="mt-3 max-w-2xl leading-7">
          The site is ready for new essays, notes, fragments, travel logs, book thoughts, music obsessions, and whatever else deserves a page.
        </p>
      </div>
    )}
  </section>
</BaseLayout>
